{
  "version": 2,
  "builds": [
    {
      "src": "api/ai-news.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/ai-news",
      "dest": "/api/ai-news.js"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/public/sitemap.xml"
    },
    {
      "src": "/og-image.png",
      "dest": "/public/og-image.png"
    },
    {
      "src": "/dev-server-manager/(.*)",
      "dest": "/public/dev-server-manager/$1"
    },
    {
      "src": "/cafe-manager/(.*)",
      "dest": "/public/cafe-manager/$1"
    },
    {
      "src": "/cafe-manager",
      "dest": "/public/cafe-manager/index.html"
    },
    {
      "src": "/komoshnik",
      "dest": "/public/komoshnik/index.html"
    },
    {
      "src": "/komoshnik/(.*)",
      "dest": "/public/komoshnik/$1"
    },
    {
      "src": "/ai-news",
      "dest": "/public/ai-news/index.html"
    },
    {
      "src": "/ai-news/(.*)",
      "dest": "/public/ai-news/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ]
}
